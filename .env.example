TZ=Asia/Shanghai

DT_SHIPMENT_DATA_ROOT=/Volumes/团队文件-DAINTY_SHIPMENT/docker/dt_shipment
DT_SHIPMENT_BACKUP_DIR=/Volumes/团队文件-DAINTY_SHIPMENT/docker/dt_shipment/backups
DT_SHIPMENT_DB_VOLUME_NAME=dt_shipment_postgres_data
DT_SHIPMENT_BACKUP_PREFIX=dt_shipment
DT_SHIPMENT_BACKUP_INTERVAL_SECONDS=21600
DT_SHIPMENT_BACKUP_KEEP_DAYS=14

DT_SHIPMENT_DB_NAME=dt_ship_manager
DT_SHIPMENT_DB_USER=postgres
DT_SHIPMENT_DB_PASSWORD=replace-with-a-strong-db-password

DT_SHIPMENT_ADMIN_USERNAME=admin
DT_SHIPMENT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
# 如果改用 bcrypt hash，可配置下面并把 DT_SHIPMENT_ADMIN_PASSWORD 置空
# DT_SHIPMENT_ADMIN_PASSWORD_HASH=

DT_SHIPMENT_JWT_SECRET=replace-with-a-long-random-secret

PRODUCT_IMAGE_ROOT=/data/assets/products
PRODUCT_IMAGE_TMP_DIR=/data/assets/uploads/tmp
PRODUCT_IMAGE_MAX_FILES=12
PRODUCT_IMAGE_MAX_FILE_MB=10
PRODUCT_IMAGE_ALLOWED_MIME=image/jpeg,image/png,image/webp
PRODUCT_IMAGE_ORIGINAL_MAX_WIDTH=1800
PRODUCT_IMAGE_ORIGINAL_JPEG_QUALITY=82
PRODUCT_IMAGE_ORIGINAL_WEBP_QUALITY=84
PRODUCT_IMAGE_THUMB_WIDTH=480
PRODUCT_IMAGE_TRASH_RETENTION_DAYS=30

DT_SHIPMENT_FRONTEND_PORT=18187
DT_SHIPMENT_BACKEND_PORT=18787
DT_SHIPMENT_SMOKE_BASE_URL=http://127.0.0.1:18187
DT_SHIPMENT_PUBLIC_HOST=ship.dainty.vip
